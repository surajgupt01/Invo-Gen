// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../prisma"
}

datasource db {
  provider = "postgresql"
}


enum Plan{
  Free
  Lite
  Pro
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  phoneNumber   String?   @unique
  image         String?
  emailVerified DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]   

  subscription  String?  @default("false")
  invoice       Invoice[]
  plan          Plan @default(Free)

  Downloads     Int? @default(0)   
  Storage       Int? @default(0)   
}
model Account {
  id                 String  @id @default(cuid())   // ✅ ADD THIS

  userId             String
  type               String
  provider           String
  providerAccountId  String

  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId]) 
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}



model Invoice {

  InvoiceId  String @unique 
  OwnerName String
  OwnerPh   String
  OwnwerBankName String?
  OwnerAccountNumber String?
  OwnerBankAddress String?
  OwerBankCode String?
  CustomerName String?
  CustomerAddress String?
  DueDate String
  IssueDate String
  Currency String
  AdditionalInfo String
  Terms String
  ItemsTable InvoiceItem[]
  subtotal    String
  tax         String
  discount    String?
  total       String
  BrandLogo String
  Signature String?
  Subject String?
  userId String
  user User @relation(fields: [userId] , references: [id] ,  onDelete: Cascade)

}

model InvoiceItem {
  id          String  @id @default(cuid())
  description String?
  quantity    String
  unitPrice   String
  discount    String?
  // taxRate     Float?
  total       String

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [InvoiceId] , onDelete: Cascade)
}

